# ============================================
# Credenciales Globales de Telegram
# (Obtener en https://my.telegram.org)
# ============================================
API_ID=12345678
API_HASH=tu_api_hash_aqui
PHONE=+34123456789

# IDs de Telegram de los usuarios que pueden enviar enlaces (separados por comas)
USUARIOS_AUTORIZADOS=123456789,987654321

# ============================================
# Configuración compartida
# ============================================
LOG_LEVEL=INFO
# Tiempo para borrar videos locales (168h = 7 días)
CLEANUP_HOURS=168

# ============================================
# Configuración Bot YouTube
# ============================================
CARPETA_DESCARGAS=./youtube_downloads
GRUPO_DESTINO=-1001111111111
MAX_HEIGHT=720

# ============================================
# Configuración Bot TikTok
# ============================================
CARPETA_DESCARGAS_TIKTOK=./tiktok_downloads
# El ID del nuevo grupo de Telegram para TikTok (Suele empezar con -100)
GRUPO_DESTINO_TIKTOK=-1002222222222
